{
  "family": "proxi-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::032847238998:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "032847238998.dkr.ecr.us-east-1.amazonaws.com/proxi-api:initial",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3002,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "PORT",
          "value": "3002"
        },
        {
          "name": "CORS_ORIGIN",
          "value": "https://proxi-agent.vercel.app/"
        },
        {
          "name": "DB_SSL_MODE",
          "value": "require"
        },
        {
          "name": "CORS_ALLOW_VERCEL_PREVIEWS",
          "value": "true"
        },
        {
          "name": "CORS_VERCEL_PREVIEW_SUFFIXES",
          "value": ".vercel.app"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:032847238998:secret:proxi/prod/database_url"
        },
        {
          "name": "CLERK_SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:032847238998:secret:proxi/prod/clerk_secret_key"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/proxi-api",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
