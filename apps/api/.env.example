PORT=3002
CORS_ORIGIN=http://localhost:3001
CORS_ALLOW_VERCEL_PREVIEWS=false
# Optional comma-separated suffixes for preview URLs, e.g. .your-team.vercel.app
# CORS_VERCEL_PREVIEW_SUFFIXES=.your-team.vercel.app

# Clerk
CLERK_SECRET_KEY=

# AWS RDS Postgres
DATABASE_URL=
DB_SSL_MODE=verify-full
DB_SSL_CA_PATH=./global-bundle.pem

# AWS + AI pipeline
AWS_REGION=us-east-1
TRANSFER_DOCS_BUCKET=
TRANSFER_UPLOAD_URL_TTL_SECONDS=900
TRANSFER_AI_QUEUE_URL=
TRANSFER_JOB_WORKER_ENABLED=true
TRANSFER_JOB_POLL_MS=3000
TEXTRACT_ENABLED=false

# OpenAI structured extraction
OPENAI_API_KEY=
OPENAI_TRANSFER_MODEL=gpt-4.1-mini
TRANSFER_AI_AUTO_REVIEW_CONFIDENCE=0.92
TRANSFER_AI_COMPLETENESS_THRESHOLD=0.9
